const CACHE = 'famemap-v1';
const FILES = [
  '/',
  '/dashboard.html',
  '/login.html',
  '/signup.html',
  '/qr.html',
  '/refer.html',
  '/feedback.html',
  '/onboarding.html',
  '/app.js',
  '/style.css'
];

self.addEventListener('install', e => {
  e.waitUntil(
    caches.open(CACHE).then(cache => cache.addAll(FILES))
  );
});

self.addEventListener('fetch', e => {
  e.respondWith(
    caches.match(e.request).then(res => res || fetch(e.request))
  );
});